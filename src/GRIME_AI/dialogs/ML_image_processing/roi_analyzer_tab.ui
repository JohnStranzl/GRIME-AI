<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ROIAnalyzerTab</class>
 <widget class="QWidget" name="ROIAnalyzerTab">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>965</width><height>700</height></rect>
  </property>
  <property name="font">
   <font><family>Arial</family><pointsize>11</pointsize></font>
  </property>
  <layout class="QVBoxLayout" name="verticalLayoutTab">

   <!-- Row 1: Folder path + Browse -->
   <item>
    <layout class="QHBoxLayout" name="horizontalLayoutFolderPath">
     <item>
      <widget class="QLineEdit" name="lineEdit_ROI_images_folder">
       <property name="placeholderText"><string>Enter folder path…</string></property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="pushButton_browse_ROI_images_folder">
       <property name="text"><string>Browse</string></property>
      </widget>
     </item>
    </layout>
   </item>

   <!-- Row 2: Left panel (clustering+metrics) + Right panel (splitter full height) -->
   <item>
    <layout class="QHBoxLayout" name="horizontalLayoutMain">

     <!-- Left panel: clustering groupbox + metrics groupbox stacked, fixed width -->
     <item>
      <layout class="QVBoxLayout" name="verticalLayoutLeftPanel">
       <item>
        <widget class="QGroupBox" name="groupBox_clusteringMethod">
         <property name="sizePolicy">
          <sizepolicy hsizetype="Fixed" vsizetype="Fixed">
           <horstretch>0</horstretch><verstretch>0</verstretch>
          </sizepolicy>
         </property>
         <property name="title"><string>Clustering Method</string></property>
         <layout class="QVBoxLayout" name="verticalLayoutClusteringInner">
          <property name="spacing"><number>2</number></property>

          <!-- K-Means radio -->
          <item>
           <widget class="QRadioButton" name="radioButton_kmeans">
            <property name="text"><string>K-Means</string></property>
            <property name="checked"><bool>true</bool></property>
            <attribute name="buttonGroup"><string>buttonGroup_clusteringMethod</string></attribute>
           </widget>
          </item>
          <item>
           <layout class="QHBoxLayout" name="horizontalLayoutKmeansParams">
            <item>
             <spacer name="spacer_kmeans_indent">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeType"><enum>QSizePolicy::Fixed</enum></property>
              <property name="sizeHint" stdset="0"><size><width>20</width><height>0</height></size></property>
             </spacer>
            </item>
            <item>
             <widget class="QLabel" name="label_numClusters">
              <property name="text"><string>Clusters:</string></property>
             </widget>
            </item>
            <item>
             <widget class="QSpinBox" name="spinBox_numClusters">
              <property name="minimum"><number>1</number></property>
              <property name="maximum"><number>10</number></property>
              <property name="value"><number>3</number></property>
             </widget>
            </item>
            <item>
             <spacer name="spacer_kmeans_right">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
             </spacer>
            </item>
           </layout>
          </item>

          <!-- GMM radio -->
          <item>
           <widget class="QRadioButton" name="radioButton_gmm">
            <property name="text"><string>GMM</string></property>
            <attribute name="buttonGroup"><string>buttonGroup_clusteringMethod</string></attribute>
           </widget>
          </item>
          <item>
           <layout class="QHBoxLayout" name="horizontalLayoutGmmParams">
            <item>
             <spacer name="spacer_gmm_indent">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeType"><enum>QSizePolicy::Fixed</enum></property>
              <property name="sizeHint" stdset="0"><size><width>20</width><height>0</height></size></property>
             </spacer>
            </item>
            <item>
             <widget class="QLabel" name="label_numClusters_gmm">
              <property name="text"><string>Clusters:</string></property>
              <property name="enabled"><bool>false</bool></property>
             </widget>
            </item>
            <item>
             <widget class="QSpinBox" name="spinBox_numClusters_gmm">
              <property name="minimum"><number>1</number></property>
              <property name="maximum"><number>10</number></property>
              <property name="value"><number>3</number></property>
              <property name="enabled"><bool>false</bool></property>
             </widget>
            </item>
            <item>
             <spacer name="spacer_gmm_right">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
             </spacer>
            </item>
           </layout>
          </item>

          <!-- Mean-Shift radio -->
          <item>
           <widget class="QRadioButton" name="radioButton_meanshift">
            <property name="text"><string>Mean-Shift</string></property>
            <attribute name="buttonGroup"><string>buttonGroup_clusteringMethod</string></attribute>
           </widget>
          </item>
          <item>
           <layout class="QHBoxLayout" name="horizontalLayoutMeanshiftRow1">
            <item>
             <spacer name="spacer_ms_indent1">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeType"><enum>QSizePolicy::Fixed</enum></property>
              <property name="sizeHint" stdset="0"><size><width>20</width><height>0</height></size></property>
             </spacer>
            </item>
            <item>
             <widget class="QCheckBox" name="checkBox_autoEstimate">
              <property name="text"><string>Auto</string></property>
              <property name="checked"><bool>true</bool></property>
              <property name="enabled"><bool>false</bool></property>
             </widget>
            </item>
            <item>
             <widget class="QLabel" name="label_quantile">
              <property name="text"><string>Quantile:</string></property>
              <property name="enabled"><bool>false</bool></property>
             </widget>
            </item>
            <item>
             <widget class="QDoubleSpinBox" name="doubleSpinBox_quantile">
              <property name="minimum"><double>0.05</double></property>
              <property name="maximum"><double>0.95</double></property>
              <property name="singleStep"><double>0.05</double></property>
              <property name="value"><double>0.20</double></property>
              <property name="enabled"><bool>false</bool></property>
             </widget>
            </item>
            <item>
             <spacer name="spacer_ms_right1">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
             </spacer>
            </item>
           </layout>
          </item>
          <item>
           <layout class="QHBoxLayout" name="horizontalLayoutMeanshiftRow2">
            <item>
             <spacer name="spacer_ms_indent2">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeType"><enum>QSizePolicy::Fixed</enum></property>
              <property name="sizeHint" stdset="0"><size><width>20</width><height>0</height></size></property>
             </spacer>
            </item>
            <item>
             <widget class="QLabel" name="label_bandwidth">
              <property name="text"><string>Bandwidth:</string></property>
              <property name="enabled"><bool>false</bool></property>
             </widget>
            </item>
            <item>
             <widget class="QDoubleSpinBox" name="doubleSpinBox_bandwidth">
              <property name="minimum"><double>1.00</double></property>
              <property name="maximum"><double>200.00</double></property>
              <property name="singleStep"><double>0.5</double></property>
              <property name="value"><double>15.00</double></property>
              <property name="enabled"><bool>false</bool></property>
             </widget>
            </item>
            <item>
             <spacer name="spacer_ms_right2">
              <property name="orientation"><enum>Qt::Horizontal</enum></property>
              <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
             </spacer>
            </item>
           </layout>
          </item>

         </layout>
        </widget>
       </item>

       <!-- Metrics groupbox -->
       <item>
        <widget class="QGroupBox" name="groupBox_metrics">
         <property name="sizePolicy">
          <sizepolicy hsizetype="Fixed" vsizetype="Preferred">
           <horstretch>0</horstretch><verstretch>0</verstretch>
          </sizepolicy>
         </property>
         <property name="title"><string>Metrics</string></property>
         <layout class="QFormLayout" name="formLayout_metrics">
          <property name="labelAlignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
          <item row="0" column="0"><widget class="QLabel" name="label_intensity"><property name="text"><string>Intensity (I):</string></property></widget></item>
          <item row="0" column="1"><widget class="QLineEdit" name="lineEdit_intensity"><property name="readOnly"><bool>true</bool></property><property name="maxLength"><number>8</number></property></widget></item>
          <item row="1" column="0"><widget class="QLabel" name="label_entropy"><property name="text"><string>Entropy (E):</string></property></widget></item>
          <item row="1" column="1"><widget class="QLineEdit" name="lineEdit_entropy"><property name="readOnly"><bool>true</bool></property><property name="maxLength"><number>8</number></property></widget></item>
          <item row="2" column="0"><widget class="QLabel" name="label_T"><property name="text"><string>T:</string></property></widget></item>
          <item row="2" column="1"><widget class="QLineEdit" name="lineEdit_Texture"><property name="readOnly"><bool>true</bool></property><property name="maxLength"><number>8</number></property></widget></item>
          <item row="3" column="0"><widget class="QLabel" name="label_GLI"><property name="text"><string>GLI:</string></property></widget></item>
          <item row="3" column="1"><widget class="QLineEdit" name="lineEdit_GLI"><property name="readOnly"><bool>true</bool></property><property name="maxLength"><number>8</number></property></widget></item>
          <item row="4" column="0"><widget class="QLabel" name="label_GCC"><property name="text"><string>GCC:</string></property></widget></item>
          <item row="4" column="1"><widget class="QLineEdit" name="lineEdit_GCC"><property name="readOnly"><bool>true</bool></property><property name="maxLength"><number>8</number></property></widget></item>
         </layout>
        </widget>
       </item>

       <!-- Vertical spacer pushes groupboxes to the top -->
       <item>
        <spacer name="spacer_leftPanelBottom">
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
        </spacer>
       </item>
      </layout>
     </item>

     <!-- Right panel: vertical splitter spanning full height -->
     <item>
      <widget class="QSplitter" name="splitter_display">
       <property name="orientation"><enum>Qt::Vertical</enum></property>
       <property name="sizePolicy">
