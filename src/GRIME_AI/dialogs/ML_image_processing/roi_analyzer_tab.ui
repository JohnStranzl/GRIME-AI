          </item>
          <item>
           <layout class="QHBoxLayout" name="horizontalLayoutKmeansParams">
            <item><spacer name="spacer_kmeans_indent"><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeType"><enum>QSizePolicy::Fixed</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>0</height></size></property></spacer></item>
