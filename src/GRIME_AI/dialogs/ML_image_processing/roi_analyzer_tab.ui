       <property name="text"><string>Browse</string></property>
      </widget>
     </item>
    </layout>
   </item>

   <!-- Row 2: Left panel + Right panel -->
   <item stretches="1">
    <layout class="QHBoxLayout" name="horizontalLayoutMain">

     <!-- Left panel: full height, fixed width -->
     <item>
      <layout class="QVBoxLayout" name="verticalLayoutLeftPanel">

       <item>
        <widget class="QGroupBox" name="groupBox_clusteringMethod">
