           <horstretch>0</horstretch><verstretch>0</verstretch>
          </sizepolicy>
         </property>
         <property name="title"><string>Clustering Method</string></property>
         <layout class="QVBoxLayout" name="verticalLayoutClusteringInner">
          <property name="spacing"><number>2</number></property>
          <item>
           <widget class="QRadioButton" name="radioButton_kmeans">
